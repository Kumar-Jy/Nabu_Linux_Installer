#!/sbin/sh
# Full-fledged linux installer for NABU by kumar_jy
OUTFD=/proc/self/fd/$2;
ZIPFILE="$3";

ui_print() {
  if $BOOTMODE; then
    echo "$1";
  else
    echo -e "ui_print $1\nui_print" >> $OUTFD;
  fi;
}
abort() { ui_print " "; ui_print "$1"; exit 1; }

# detect Magisk app/booted flashing
BOOTMODE=false;
ps | grep zygote | grep -v grep >/dev/null && BOOTMODE=true;
$BOOTMODE || ps -A 2>/dev/null | grep zygote | grep -v grep >/dev/null && BOOTMODE=true;

# /dev/tmp is safe for both booted and recovery installs
tmp=/dev/tmp/linux-install;
rm -rf $tmp;
mkdir -p $tmp;

ui_print "#############################################";
ui_print "#              Linux installer              #";
ui_print "#############################################";
ui_print " ";
linux_part=/dev/block/by-name/linux;
zext=$tmp/bin/7zzs;
mke2fs=$tmp/bin/mke2fs;

unzip -o "$ZIPFILE" "bin/*" -d $tmp || abort "Failed to extract bin";
chmod -R 0777 $tmp;

ui_print "Checking linux partition device: $linux_part";
if [ ! -e "$linux_part" ]; then
  abort "Linux partition device not found: $linux_part";
fi;
if mount | grep -q " $linux_part "; then
  ui_print "Linux partition $linux_part is mounted, unmounting...";
  umount -lf "$linux_part" || abort "Failed to unmount linux partition $linux_part";
fi;
blockdev --setrw "$linux_part";
ui_print "Formatting and flashing linux image";

$mke2fs -t ext4 -F "$linux_part" || ui_print "failed to erase linux partition";

$zext e -so "$ZIPFILE" "image/linux.img" > "$linux_part" 2> "$tmp/7z.err" || abort "Failed to dump linux image";

ui_print " ";
ui_print "Done flashing linux!";

ui_print "#############################################";
ui_print "#             Boot Configration             #";
ui_print "#############################################";
ui_print " ";
esp_part=/dev/block/by-name/esp;
mkdir -p $tmp/esp;

if mount | grep -q " $esp_part "; then
  ui_print "ESP partition $esp_part already mounted, forcing unmount...";
  umount -lf $esp_part || abort "Failed to unmount existing ESP partition";
fi
mount "$esp_part" "$tmp/esp" || abort "Failed to mount ESP partition";
mkdir -p $tmp/esp/efi;
unzip -o "$ZIPFILE" "efi/*" -d $tmp/esp || abort "Failed to extract efi";
umount -lf "$esp_part" 2>/dev/null

ui_print " ";
ui_print "Done setup boot configration !";

ui_print "#############################################";
ui_print "#            DBPK UEFI installer            #";
ui_print "#############################################";
ui_print " ";

# DBKP Flashable Linux Installer
# modified from the TWRP A/B Installer Backend by osm0sis, Dees_Troy and topjohnwu
# target partition without the slot suffix
target=/dev/block/bootdevice/by-name/boot;

name=$(basename $target);

ui_print "Unpacking the DBKP installer...";

unzip -o "$ZIPFILE" "DBKP/*" -d $tmp || abort "Failed to extract DBKP!";

cd $tmp/DBKP;
uefipayload=`(ls *_EFI.fd) 2>/dev/null`;
dbkpcfg=`(ls DualBoot.*.cfg) 2>/dev/null`;
shellcode=`(ls ShellCode.*.bin) 2>/dev/null`;
[ "$uefipayload" ] || abort "No UEFI payload found in zip!";
[ "$dbkpcfg" ] || abort "No dbkp config found in zip!";
[ "$shellcode" ] || abort "No dbkp shellcode found in zip!";

tool=$tmp/DBKP/magiskboot;
patcher=$tmp/DBKP/DualBootKernelPatcher;
chmod 755 $tool;
chmod 755 $patcher;

backuppath="/sdcard/boot_backup"
slot=$(getprop ro.boot.slot_suffix)
ui_print " ";
ui_print "Current slot: $slot."

# if [ "$slot" ]; then
  if [ "$uefipayload" ]; then
    ui_print "Running image patcher on $name$slot...";
    dd if=$target$slot of=boot.img || abort "Failed to dump image!";

    ui_print "Backing up original boot$slot.img..."
    rm -f "$backuppath$slot.img"
    cp -f boot.img "$backuppath$slot.img"
    ui_print "Original boot$slot backed up to $backuppath$slot.img!"

    $tool unpack -h boot.img || abort "Failed to unpack image!";

    $patcher kernel $uefipayload patchedKernel $dbkpcfg $shellcode || abort "Failed to patch the kernel";
    mv patchedKernel kernel

    $tool repack boot.img || abort "Failed to repack image!";
    $tool cleanup;
  fi;
# else
#   ui_print "Failed to get current slot!";
#   abort "Exiting...";
# fi;

blockdev --setrw $target$slot;
cat new-boot.img /dev/zero > $target$slot 2>/dev/null || true;
rm -f new-boot.img;

if [ "$uefipayload" ]; then
  ui_print " ";
  ui_print "Image patching complete!";
fi;

ui_print " ";
ui_print "Done flashing efi!";